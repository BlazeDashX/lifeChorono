// ─── ADD TO: prisma/schema.prisma ─────────────────────────────────────────
// Add these two lines to your existing User model:
//   scheduleTemplates ScheduleTemplate[]
//   ghostEntries      GhostEntry[]
//
// Then run: npx prisma migrate dev --name add_schedule_templates
// ──────────────────────────────────────────────────────────────────────────

model ScheduleTemplate {
  id         String          @id @default(cuid())
  userId     String
  name       String          // "Weekday", "Weekend", "Rest Day"
  daysOfWeek Int[]           // 0=Sun 1=Mon ... 6=Sat
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks     TemplateBlock[]
  @@index([userId])
}

model TemplateBlock {
  id            String           @id @default(cuid())
  templateId    String
  title         String
  category      String           // productive | leisure | restoration | neutral
  startHour     Int              // 0-23
  startMinute   Int              // 0 or 30 (15-min increments fine too)
  endHour       Int
  endMinute     Int
  order         Int              @default(0)
  // Exception memory
  // editCounts:    { "1": 3 }   -- how many times edited on this weekday
  // adjustedTimes: { "1": { startHour:6, startMinute:30, endHour:7, endMinute:30 } }
  editCounts    Json             @default("{}")
  adjustedTimes Json             @default("{}")
  template      ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  @@index([templateId])
}

model GhostEntry {
  id               String      @id @default(cuid())
  userId           String
  date             DateTime    // UTC midnight of the day
  templateBlockId  String
  title            String
  category         String
  startTime        DateTime
  endTime          DateTime
  confidence       Float       @default(1.0)   // 1.0 | 0.85 | 0.7 | 0.5
  status           GhostStatus @default(PENDING)
  confirmedEntryId String?     @unique          // set when user confirms
  createdAt        DateTime    @default(now())
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date, templateBlockId])
  @@index([userId, date])
}

enum GhostStatus {
  PENDING     // shown as ghost on timeline
  CONFIRMED   // tapped confirm -> real entry created
  EDITED      // time adjusted before confirming
  DISMISSED   // user swiped away (not today)
}
